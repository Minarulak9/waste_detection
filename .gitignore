# ============================================================
# Smart Waste Segregation System — .gitignore
# ============================================================

# ── Security ────────────────────────────────────────────────
ssh.txt
.env
*.pem
*.key
*.credentials

# ── Claude AI session files ──────────────────────────────────
.claude/

# ── Dataset (large, download via Roboflow) ──────────────────
wastemanagement-2/

# ── Base YOLO model weights (downloadable from Ultralytics) ─
# Our trained best model (codebase/BEST_MODELS/*.pt) is kept.
yolo11s.pt
yolo26n.pt

# ── YOLO / Ultralytics training run outputs ─────────────────
runs/
codebase/dual_stream_bifpn/runs/
codebase/results/

# ── Model comparison outputs (training batch images, CSVs) ──
model_comparison/

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────
venv/
env/
.venv/
ENV/

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── LaTeX build artifacts ────────────────────────────────────
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
*.bcf
*.run.xml
*.nav
*.snm
*.vrb
# Compiled PDF output (keep source .tex, ignore compiled output)
final_project_report/*.pdf
final_project_report/thesis.pdf

# ── Planning / research documents in docs/ ───────────────────
# (keep springer_paper.tex and figures; ignore Word/PDF drafts)
docs/*.docx
docs/*.pdf
docs/springer_paper.md

# ── Presentation slides ──────────────────────────────────────
presentation/

# ── Project report template (original blank template) ────────
Project_Report_Template/


# ── OS / editor junk ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/

# streamlit run demo_app.py